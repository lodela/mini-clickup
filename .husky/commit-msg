#!/usr/bin/env sh
msg=$(cat "$1")

# Pattern: type(scope): description  OR  type: description
pattern='^(feat|fix|docs|style|refactor|perf|test|chore|revert|build|ci)(\(.+\))?: .{1,100}$'

if ! echo "$msg" | grep -qE "$pattern"; then
  echo ""
  echo "✗ husky - commit-msg: mensaje de commit inválido"
  echo ""
  echo "  Formato requerido: <tipo>(<scope>): <descripción>"
  echo ""
  echo "  Tipos válidos: feat, fix, docs, style, refactor, perf, test, chore, revert, build, ci"
  echo ""
  echo "  Ejemplos válidos:"
  echo "    feat(auth): agregar login con email y password"
  echo "    fix(tasks): resolver error 500 en DELETE /api/teams/:id"
  echo "    docs(readme): actualizar instrucciones de instalación"
  echo ""
  echo "  Tu mensaje: \"$msg\""
  echo ""
  exit 1
fi
