# Git Ignore Pattern

# Dependencies
node_modules/
.pnp
.pnp.js

# Testing
coverage/
*.lcov
.nyc_output/

# Production builds
dist/
build/
build-qa/
*.tsbuildinfo

# Environment variables — never commit, monorepo-wide coverage
.env
.env.local
.env.development
.env.production
.env.development.local
.env.test.local
.env.production.local
**/.env
**/.env.local
**/.env.*.local
**/.env.development
**/.env.production

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# OS files
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# IDE
.vscode/
.idea/
*.sublime-workspace
*.sublime-project

# Temporary files
*.tmp
*.temp
.cache/

# Misc
.eslintcache
.stylelintcache

# External AI workspace artifacts
.sisyphus/

# Figma API cache
figma-login-node.json

# Windows artifacts
nul

# PowerShell artifacts
$null
